# ── Ports ────────────────────────────────────────────────────
HTTP_PORT=8080
HTTPS_PORT=8443

# ── Base de données ──────────────────────────────────────────
POSTGRES_DB=hermes
POSTGRES_USER=hermes
POSTGRES_PASSWORD=change-this-password

# ── Application ───────────────────────────────────────────────
SECRET_KEY=change-this-secret-key-minimum-32-chars
ENVIRONMENT=production

# ── API IA ────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Frontend / Auth ───────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://votre-domaine.ch/api
NEXTAUTH_URL=https://votre-domaine.ch
NEXTAUTH_SECRET=change-this-nextauth-secret

# ── CORS ──────────────────────────────────────────────────────
CORS_ORIGINS=https://votre-domaine.ch
